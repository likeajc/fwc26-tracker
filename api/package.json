{
  "name": "fwc26-tracker-api",
  "version": "1.0.0",
  "description": "REST API for FIFA World Cup 2026 — live scores, match schedule, group standings, 48 teams, 16 stadiums.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "cross-env NODE_ENV=development nodemon index.js",
    "prod": "cross-env NODE_ENV=production node index.js",
    "start:dev": "cross-env NODE_ENV=development nodemon index.js",
    "start:prod": "cross-env NODE_ENV=production node index.js",
    "import:all": "node import-groups.js && node import-teams.js && node import-stadiums.js && node import-matches.js",
    "import:groups": "node import-groups.js",
    "import:teams": "node import-teams.js",
    "import:stadiums": "node import-stadiums.js",
    "import:matches": "node import-matches.js",
    "update:live": "node scripts/auto-updater.js",
    "pm:start": "pm2 start ecosystem.config.js",
    "pm:stop": "pm2 stop ecosystem.config.js",
    "pm:restart": "pm2 restart ecosystem.config.js",
    "pm:logs": "pm2 logs"
  },
  "keywords": [
    "fifa-world-cup-2026",
    "world-cup-api",
    "football-api",
    "soccer-api",
    "free-api",
    "free-football-api",
    "free-soccer-api",
    "free-sports-api",
    "live-scores",
    "live-score-api",
    "live-results",
    "rest-api",
    "express",
    "node",
    "mongodb",
    "swagger",
    "openapi",
    "jwt-authentication",
    "real-time-scores",
    "sports-api",
    "sports-data",
    "48-teams",
    "usa-mexico-canada",
    "world-cup-schedule",
    "world-cup-fixtures",
    "world-cup-standings",
    "world-cup-groups",
    "football-data",
    "soccer-data",
    "open-source"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.4",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.17.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^6.2.5",
    "mongoose": "^6.2.5",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^2.0.15",
    "pm2": "^5.4.3"
  }
}
